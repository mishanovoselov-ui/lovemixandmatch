---
/**
 * BookFlip — interactive kasane book viewer
 *
 * Two independent halves (left / right), each with arrow navigation.
 * 3 left pages × 3 right pages = 9 unique combinations.
 *
 * Usage in IndexPage.astro:
 *
 *   import BookFlip from './BookFlip.astro';
 *
 *   <BookFlip
 *     leftImages={[
 *       { src: '/images/spreads/left-01.jpg', alt: 'Volume I — page 1' },
 *       { src: '/images/spreads/left-02.jpg', alt: 'Volume I — page 2' },
 *       { src: '/images/spreads/left-03.jpg', alt: 'Volume I — page 3' },
 *     ]}
 *     rightImages={[
 *       { src: '/images/spreads/right-01.jpg', alt: 'Volume II — page 1' },
 *       { src: '/images/spreads/right-02.jpg', alt: 'Volume II — page 2' },
 *       { src: '/images/spreads/right-03.jpg', alt: 'Volume II — page 3' },
 *     ]}
 *   />
 *
 * Image dimensions: 19×27cm per half → use ~760×1080px JPGs for 2× displays.
 * Drop files into public/images/spreads/ and update the src paths above.
 */

export interface PageImage {
  src: string;
  alt: string;
}

export interface Props {
  leftImages?: PageImage[];
  rightImages?: PageImage[];
  // Labels for accessibility / UI
  labelLeft?: string;
  labelRight?: string;
  labelPrev?: string;
  labelNext?: string;
  labelOf?: string;       // e.g. "of" → "1 of 3"
}

const {
  leftImages  = [],
  rightImages = [],
  labelLeft   = 'Volume I',
  labelRight  = 'Volume II',
  labelPrev   = 'Previous',
  labelNext   = 'Next',
  labelOf     = '/',
} = Astro.props;

// Placeholder count — always show 3 slots
const LEFT_COUNT  = leftImages.length  || 3;
const RIGHT_COUNT = rightImages.length || 3;
---

<div class="bf" data-book-flip>

  <!-- ── LEFT HALF ───────────────────────────── -->
  <div class="bf__half bf__half--left">
    <div class="bf__label" aria-hidden="true">{labelLeft}</div>

    <div class="bf__stage" data-side="left" aria-live="polite" aria-label={labelLeft}>
      {leftImages.length > 0
        ? leftImages.map((img, i) => (
            <div class="bf__slide" class:list={[{ 'bf__slide--active': i === 0 }]} aria-hidden={i !== 0 ? 'true' : undefined}>
              <img src={img.src} alt={img.alt} loading={i === 0 ? 'eager' : 'lazy'} draggable="false" />
            </div>
          ))
        : Array.from({ length: LEFT_COUNT }).map((_, i) => (
            <div class="bf__slide bf__slide--placeholder" class:list={[{ 'bf__slide--active': i === 0 }]} aria-hidden={i !== 0 ? 'true' : undefined}>
              <div class="bf__placeholder">
                <span class="bf__placeholder-num">{i + 1}</span>
                <span class="bf__placeholder-hint">left-0{i + 1}.jpg</span>
              </div>
            </div>
          ))
      }
    </div>

    <div class="bf__controls">
      <button class="bf__btn" data-side="left" data-dir="-1" aria-label={`${labelPrev} ${labelLeft}`}>
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M13 4L7 10L13 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <span class="bf__counter" data-counter="left">
        <span data-current-left>1</span>
        <span class="bf__counter-sep">{labelOf}</span>
        <span>{LEFT_COUNT}</span>
      </span>
      <button class="bf__btn" data-side="left" data-dir="1" aria-label={`${labelNext} ${labelLeft}`}>
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M7 4L13 10L7 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- ── SPINE ────────────────────────────────── -->
  <div class="bf__spine" aria-hidden="true">
    <div class="bf__spine-line"></div>
  </div>

  <!-- ── RIGHT HALF ──────────────────────────── -->
  <div class="bf__half bf__half--right">
    <div class="bf__label" aria-hidden="true">{labelRight}</div>

    <div class="bf__stage" data-side="right" aria-live="polite" aria-label={labelRight}>
      {rightImages.length > 0
        ? rightImages.map((img, i) => (
            <div class="bf__slide" class:list={[{ 'bf__slide--active': i === 0 }]} aria-hidden={i !== 0 ? 'true' : undefined}>
              <img src={img.src} alt={img.alt} loading={i === 0 ? 'eager' : 'lazy'} draggable="false" />
            </div>
          ))
        : Array.from({ length: RIGHT_COUNT }).map((_, i) => (
            <div class="bf__slide bf__slide--placeholder" class:list={[{ 'bf__slide--active': i === 0 }]} aria-hidden={i !== 0 ? 'true' : undefined}>
              <div class="bf__placeholder">
                <span class="bf__placeholder-num">{i + 1}</span>
                <span class="bf__placeholder-hint">right-0{i + 1}.jpg</span>
              </div>
            </div>
          ))
      }
    </div>

    <div class="bf__controls">
      <button class="bf__btn" data-side="right" data-dir="-1" aria-label={`${labelPrev} ${labelRight}`}>
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M13 4L7 10L13 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <span class="bf__counter" data-counter="right">
        <span data-current-right>1</span>
        <span class="bf__counter-sep">{labelOf}</span>
        <span>{RIGHT_COUNT}</span>
      </span>
      <button class="bf__btn" data-side="right" data-dir="1" aria-label={`${labelNext} ${labelRight}`}>
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M7 4L13 10L7 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>

</div>

<!-- ── KEYBOARD HINT ─────────────────────────── -->
<p class="bf__hint">
  <kbd>←</kbd><kbd>→</kbd> left volume &nbsp;·&nbsp; <kbd>A</kbd><kbd>D</kbd> right volume
</p>

<script>
  document.querySelectorAll<HTMLElement>('[data-book-flip]').forEach(root => {
    const state = { left: 0, right: 0 };

    const leftSlides   = Array.from(root.querySelectorAll<HTMLElement>('[data-side="left"] .bf__slide'));
    const rightSlides  = Array.from(root.querySelectorAll<HTMLElement>('[data-side="right"] .bf__slide'));
    const leftCounter  = root.querySelector<HTMLElement>('[data-current-left]');
    const rightCounter = root.querySelector<HTMLElement>('[data-current-right]');

    function go(side: 'left' | 'right', dir: 1 | -1) {
      const slides  = side === 'left' ? leftSlides  : rightSlides;
      const counter = side === 'left' ? leftCounter  : rightCounter;
      if (!slides.length) return;

      const current = state[side];
      const next    = (current + dir + slides.length) % slides.length;

      // Exit direction class
      const exitClass = dir > 0 ? 'bf__slide--exit-up' : 'bf__slide--exit-down';
      const enterClass = dir > 0 ? 'bf__slide--enter-down' : 'bf__slide--enter-up';

      const currentSlide = slides[current];
      const nextSlide    = slides[next];

      // Prepare next slide (offscreen, no transition yet)
      nextSlide.classList.add(enterClass);
      nextSlide.classList.add('bf__slide--active');
      nextSlide.removeAttribute('aria-hidden');

      // Force reflow so transition fires
      void nextSlide.offsetWidth;

      // Animate out current, animate in next
      currentSlide.classList.add(exitClass);
      currentSlide.classList.remove('bf__slide--active');
      nextSlide.classList.remove(enterClass);

      // Cleanup after transition
      const cleanup = () => {
        currentSlide.classList.remove(exitClass);
        currentSlide.setAttribute('aria-hidden', 'true');
        currentSlide.removeEventListener('transitionend', cleanup);
      };
      currentSlide.addEventListener('transitionend', cleanup, { once: true });

      state[side] = next;
      if (counter) counter.textContent = String(next + 1);
    }

    // Arrow buttons
    root.querySelectorAll<HTMLButtonElement>('[data-side][data-dir]').forEach(btn => {
      btn.addEventListener('click', () => {
        const side = btn.dataset.side as 'left' | 'right';
        const dir  = Number(btn.dataset.dir) as 1 | -1;
        go(side, dir);
      });
    });

    // Keyboard: ← → for left, A D for right
    window.addEventListener('keydown', (e: KeyboardEvent) => {
      // Only when no input focused
      if ((e.target as HTMLElement).matches('input,textarea,select,button')) return;
      if (e.key === 'ArrowLeft')  go('left',  -1);
      if (e.key === 'ArrowRight') go('left',   1);
      if (e.key === 'a' || e.key === 'A') go('right', -1);
      if (e.key === 'd' || e.key === 'D') go('right',  1);
    });

    // Touch swipe (per half)
    (['left', 'right'] as const).forEach(side => {
      const stage = root.querySelector<HTMLElement>(`[data-side="${side}"].bf__stage`);
      if (!stage) return;
      let startX = 0;
      stage.addEventListener('touchstart', (e: TouchEvent) => { startX = e.touches[0].clientX; }, { passive: true });
      stage.addEventListener('touchend',   (e: TouchEvent) => {
        const dx = e.changedTouches[0].clientX - startX;
        if (Math.abs(dx) < 40) return;
        go(side, dx < 0 ? 1 : -1);
      }, { passive: true });
    });
  });
</script>

<style>
/* ── Container ───────────────────────────────── */
.bf {
  display: flex;
  align-items: stretch;
  gap: 0;
  width: 100%;
  max-width: 820px;
  margin: 0 auto;
  user-select: none;
}

/* ── Half ────────────────────────────────────── */
.bf__half {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.25rem;
}

/* ── Volume label ─────────────────────────────── */
.bf__label {
  font-size: 0.62rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gold);
  opacity: 0.7;
}

/* ── Stage (image viewport) ─────────────────── */
.bf__stage {
  position: relative;
  width: 100%;
  aspect-ratio: 19 / 27;   /* portrait — matches each volume's real proportions */
  overflow: hidden;
  background: #E8E4DC;
  border: 1px solid rgba(0,0,0,.08);
  cursor: pointer;
}

/* Spine side borders */
.bf__half--left  .bf__stage { border-right: none; }
.bf__half--right .bf__stage { border-left:  none; }

/* ── Slides ──────────────────────────────────── */
.bf__slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  transform: translateY(0);
  transition: opacity 0.45s cubic-bezier(0.4, 0, 0.2, 1),
              transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
  pointer-events: none;
}

.bf__slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.bf__slide--active {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

/* Transition states */
.bf__slide--exit-up   { opacity: 0; transform: translateY(-6%); }
.bf__slide--exit-down { opacity: 0; transform: translateY(6%); }
.bf__slide--enter-up  { opacity: 0; transform: translateY(-6%); transition: none; }
.bf__slide--enter-down{ opacity: 0; transform: translateY(6%); transition: none; }

/* ── Placeholder ─────────────────────────────── */
.bf__placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  background: #E8E4DC;
}
.bf__placeholder-num {
  font-family: var(--font-serif);
  font-style: italic;
  font-size: 3rem;
  color: rgba(200,16,46,.12);
  line-height: 1;
}
.bf__placeholder-hint {
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  color: #999;
  opacity: 0.6;
}

/* ── Spine ───────────────────────────────────── */
.bf__spine {
  width: 12px;
  flex-shrink: 0;
  display: flex;
  justify-content: center;
  align-items: stretch;
  padding: 2.5rem 0;
}
.bf__spine-line {
  width: 1px;
  background: linear-gradient(
    to bottom,
    transparent,
    rgba(200,16,46,.25) 20%,
    rgba(200,16,46,.45) 50%,
    rgba(200,16,46,.25) 80%,
    transparent
  );
}

/* ── Controls ────────────────────────────────── */
.bf__controls {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.bf__btn {
  width: 36px;
  height: 36px;
  border: 1px solid rgba(0,0,0,.2);
  background: transparent;
  color: #555;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background 0.2s, border-color 0.2s, color 0.2s;
  border-radius: 1px;
  flex-shrink: 0;
}
.bf__btn:hover {
  background: rgba(200,16,46,.06);
  border-color: #C8102E;
  color: #C8102E;
}
.bf__btn:active {
  background: rgba(200,16,46,.12);
}

.bf__counter {
  display: flex;
  align-items: center;
  gap: 0.3rem;
  font-size: 0.75rem;
  color: #999;
  letter-spacing: 0.08em;
  min-width: 52px;
  justify-content: center;
}
.bf__counter-sep {
  opacity: 0.4;
}

/* ── Keyboard hint ───────────────────────────── */
.bf__hint {
  text-align: center;
  margin-top: 1.5rem;
  font-size: 0.68rem;
  color: var(--ivory-ghost);
  letter-spacing: 0.06em;
  opacity: 0.5;
}
.bf__hint kbd {
  display: inline-block;
  padding: 0.1em 0.4em;
  border: 1px solid currentColor;
  border-radius: 2px;
  font-size: 0.65rem;
  margin: 0 0.1em;
  font-family: var(--font-sans);
}

/* ── Responsive ──────────────────────────────── */
@media (max-width: 600px) {
  .bf { max-width: 100%; }
  .bf__spine { width: 6px; }
  .bf__btn { width: 32px; height: 32px; }
  .bf__hint { display: none; }
}
</style>
