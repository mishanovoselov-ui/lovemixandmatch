---
import Layout from '../layouts/Layout.astro';
import BookFlip from './BookFlip.astro';
import Gallery from './Gallery.astro';
import SalesMarquee from './SalesMarquee.astro';
import type { Locale, SiteContent } from '../i18n/content.ts';

export interface Props {
  locale: Locale;
  c: SiteContent;
}

const { locale, c } = Astro.props;

const langPaths: Record<Locale, string> = { en: '/', ru: '/ru/' };
const langLabels: Record<Locale, { en: string; ru: string }> = {
  en: { en: 'EN', ru: 'RU' },
  ru: { en: 'EN', ru: 'РУ' },
};
const labels = langLabels[locale];
---

<Layout
  title={c.meta.title}
  description={c.meta.description}
  lang={c.meta.lang}
>

<!-- ══ NAV ══════════════════════════════════ -->
<nav class="nav">
  <div class="container nav__inner">
    <a href={langPaths[locale]} class="nav__logo" aria-label="Sveta Dorosheva">
      <svg class="nav__logo-img" viewBox="0 0 88 88" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
        <path d="M66.14.12c-3.76,7.62-7.18,14.53-10.73,21.71,11.35.73,20.35,5.22,26.72,14.36,14.05,20.16,1.46,49.03-22.82,51.25-12.16,1.11-24.5.19-37.39.19,3.62-7.34,7.07-14.35,10.63-21.6-12.09-.85-21.51-5.82-27.78-16.06C-8.06,29.02,6.44.99,30.63.19c11.59-.38,23.2-.07,35.51-.07ZM54.63,22.1c-8.25,0-15.86-.27-23.43.1-4.7.23-8.55,4.68-9.04,9.3-.57,5.38,2.12,9.92,7.1,11.68,4.35,1.54,8.88.5,13.33.73.9.05,1.42-.58,1.8-1.33,3.34-6.66,6.67-13.33,10.25-20.48ZM33.33,65.83c8.11,0,15.35.15,22.58-.05,4.93-.14,9.14-4.19,9.88-8.91.79-5.08-1.65-9.92-6.23-11.88-4.67-2-9.62-.84-14.45-.94-.48-.01-1.17.65-1.44,1.17-3.38,6.65-6.7,13.33-10.34,20.62Z"/>
      </svg>
    </a>
    <div class="nav__langs">
      <a href="/"    class:list={['nav__lang', { 'nav__lang--active': locale === 'en' }]} aria-current={locale === 'en' ? 'page' : undefined}>{labels.en}</a>
      <span class="nav__sep">·</span>
      <a href="/ru/" class:list={['nav__lang', { 'nav__lang--active': locale === 'ru' }]} aria-current={locale === 'ru' ? 'page' : undefined}>{labels.ru}</a>
    </div>
  </div>
</nav>

<!-- ══ HERO ══════════════════════════════════ -->
<section class="hero">
  <div class="container hero__inner">

    <img
      src="/images/love-logo.png"
      alt="Love — Mix & Match Shunga Ehon by Sveta Dorosheva"
      class="hero__logo"
      data-hero-logo
      width="600"
      height="auto"
    />

    <p class="hero__tagline" data-hero-tagline>
      {c.hero.subtitle[0]} &nbsp;·&nbsp; {c.hero.subtitle[1]}
    </p>

    <p class="hero__edition" data-hero-edition>
      {c.hero.metaEdition} &nbsp;·&nbsp; {c.hero.metaExtra}
    </p>

    <div class="hero__cta" data-hero-cta>
      <a href="#buy" class="btn btn-primary">{c.hero.ctaPrimary}</a>
      <a href="#mechanic" class="btn btn-ghost">{c.hero.ctaSecondary}</a>
    </div>

  </div>
  <div class="hero__scroll" aria-hidden="true"><div class="hero__scroll-line"></div></div>
</section>

<!-- ══ PULLQUOTE ═════════════════════════════ -->
<section class="pullquote">
  <div class="container">
    <div class="ornament" data-reveal><span>✦</span></div>
    <blockquote class="pullquote__text" data-reveal>{c.pullquote}</blockquote>
    <div class="ornament" data-reveal><span>✦</span></div>
  </div>
</section>

<!-- ══ ABOUT ═════════════════════════════════ -->
<section class="about" id="about">
  <div class="container about__inner">
    <div class="about__content">
      <p class="eyebrow" data-reveal>{c.about.eyebrow}</p>
      <h2 class="about__title" data-reveal>
        {c.about.title.map((line, i) => (
          <>{line}{i < c.about.title.length - 1 && <br/>}</>
        ))}
      </h2>
      {c.about.body.map(para => (
        <p class="about__body" data-reveal set:html={para.replace(/\*\*(.+?)\*\*/g, '<em>$1</em>')} />
      ))}
      <div class="about__facts" data-reveal>
        <div class="about__fact">
          <span class="about__fact-num">1600</span>
          <span class="about__fact-label">{c.about.factCombinations}</span>
        </div>
        <div class="about__fact">
          <span class="about__fact-num">2</span>
          <span class="about__fact-label">{c.about.factVolumes}</span>
        </div>
        <div class="about__fact">
          <span class="about__fact-num">∞</span>
          <span class="about__fact-label">{c.about.factEdition}</span>
        </div>
      </div>
    </div>
    <div class="about__gallery">
      <div class="about__img about__img--1">
        <img src="/images/promo/book-02.jpg" alt={c.about.imgLabels[0]} loading="lazy" />
      </div>
      <div class="about__img about__img--2">
        <img src="/images/promo/book-01.jpg" alt={c.about.imgLabels[1]} loading="lazy" />
      </div>
      <div class="about__img about__img--3">
        <img src="/images/promo/book-03.jpg" alt={c.about.imgLabels[2]} loading="lazy" />
      </div>
    </div>
  </div>
</section>

<!-- ══ MECHANIC ═══════════════════════════════ -->
<section class="mechanic" id="mechanic">
  <div class="container">
    <p class="eyebrow" data-reveal>{c.mechanic.eyebrow}</p>
    <h2 class="mechanic__title" data-reveal>{c.mechanic.title}</h2>
    <div class="mechanic__list">
      {c.mechanic.items.map((item, i) => (
        <article class="mechanic__item" data-reveal-stagger>
          <span class="mechanic__index" aria-hidden="true">0{i + 1}</span>
          <div class="mechanic__item-body">
            <h3 class="mechanic__label">{item.label}</h3>
            <p class="mechanic__body">{item.body}</p>
          </div>
          <div class="mechanic__kanji" aria-hidden="true">{item.term}</div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- ══ MITATE GALLERY ════════════════════════ -->
<section class="mitate-gallery" id="gallery">
  <div class="container">
    <p class="eyebrow" style="text-align:center" data-reveal>{c.mitateGallery.eyebrow}</p>
    <h2 class="mitate-gallery__title" data-reveal>{c.mitateGallery.title}</h2>
    <p class="mitate-gallery__intro" data-reveal>{c.mitateGallery.intro}</p>
    <Gallery items={c.mitateGallery.items} />
  </div>
</section>

<!-- ══ VIDEO ══════════════════════════════════ -->
<section class="video-section">
  <div class="container">
    <p class="eyebrow" style="text-align:center" data-reveal>{c.video.eyebrow}</p>
    <h2 class="video__title" data-reveal>{c.video.title}</h2>
    <div class="video__wrap" data-reveal>
      {c.video.driveId ? (
        <iframe
          src={`https://drive.google.com/file/d/${c.video.driveId}/preview`}
          title={c.video.title}
          frameborder="0"
          allow="autoplay"
          allowfullscreen
          loading="lazy"
        ></iframe>
      ) : c.video.youtubeId ? (
        <iframe
          src={`https://www.youtube-nocookie.com/embed/${c.video.youtubeId}?rel=0&modestbranding=1&color=white`}
          title={c.video.title}
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      ) : (
        <div class="video__placeholder">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none" aria-hidden="true">
            <circle cx="24" cy="24" r="23" stroke="currentColor" stroke-width="1" opacity="0.3"/>
            <path d="M19 16L35 24L19 32V16Z" fill="currentColor" opacity="0.4"/>
          </svg>
          <span>Video — add driveId or youtubeId to content.ts</span>
        </div>
      )}
    </div>
  </div>
</section>

<!-- ══ BOOK FLIP (kasane interactive) ══════════ -->
<section class="kasane" id="kasane">
  <div class="container">
    <p class="eyebrow" style="text-align:center" data-reveal>{c.gallery.eyebrow}</p>
    <h2 class="kasane__title" data-reveal>{c.gallery.title}</h2>
    <p class="kasane__sub" data-reveal>
      {locale === 'ru'
        ? 'Листайте каждый том отдельно — создавайте свою комбинацию'
        : 'Flip each volume independently — create your own combination'}
    </p>
    <div data-reveal>
      <BookFlip
        leftImages={c.gallery.images.filter((_, i) => i % 2 === 0)}
        rightImages={c.gallery.images.filter((_, i) => i % 2 === 1)}
        labelLeft={locale === 'ru' ? 'Том I' : 'Volume I'}
        labelRight={locale === 'ru' ? 'Том II' : 'Volume II'}
        labelPrev={locale === 'ru' ? 'Назад' : 'Prev'}
        labelNext={locale === 'ru' ? 'Далее' : 'Next'}
        labelOf={locale === 'ru' ? '/' : '/'}
      />
    </div>
  </div>
</section>

<!-- ══ ARTIST ════════════════════════════════ -->
<section class="artist">
  <div class="container artist__inner">
    <div class="artist__portrait">
      <!-- swap: <img src="/images/artist.jpg" alt={c.artist.portraitAlt} /> -->
      <div class="artist__portrait-placeholder">
        <span set:html={c.artist.portraitPlaceholder.replace('\n', '<br/>')} />
      </div>
      <div class="artist__portrait-frame" aria-hidden="true"></div>
    </div>
    <div class="artist__content">
      <p class="eyebrow">{c.artist.eyebrow}</p>
      <h2 class="artist__name">{c.artist.name}</h2>
      {c.artist.bio.map(p => <p class="artist__bio">{p}</p>)}

      {c.artist.clients && (
        <p class="artist__clients">{c.artist.clients}</p>
      )}

      {c.artist.awards?.length > 0 && (
        <ul class="artist__awards" aria-label="Awards">
          {c.artist.awards.map(a => (
            <li class="artist__award">
              <span class="artist__award-year">{a.year}</span>
              <span class="artist__award-name">{a.award}</span>
              <span class="artist__award-result">{a.result}</span>
            </li>
          ))}
        </ul>
      )}

      <a href="https://www.svetadorosheva.com" target="_blank" rel="noopener" class="btn btn-outline artist__link">
        {c.artist.cta}
      </a>
    </div>
  </div>
</section>

<!-- ══ SALES MARQUEE ══════════════════════════ -->
<SalesMarquee items={c.sales.items} label={c.sales.label} eyebrow={c.sales.eyebrow} />

<!-- ══ BUY ═════════════════════════════════════ -->
<section class="buy" id="buy">
  <div class="container">
    <p class="eyebrow" style="text-align:center">{c.buy.eyebrow}</p>
    <h2 class="buy__title">{c.buy.title}</h2>
    <p class="buy__subtitle">{c.buy.subtitle}</p>
    <div class="buy__list">
      {c.buy.links.map((link, i) => (
        <a
          href={link.url}
          target={link.url.startsWith('mailto') ? undefined : '_blank'}
          rel={link.url.startsWith('mailto') ? undefined : 'noopener'}
          class:list={['buy__row', { 'buy__row--featured': link.featured }]}
          data-reveal-stagger
        >
          <span class="buy__row-index" aria-hidden="true">0{i + 1}</span>
          <span class="buy__row-body">
            <span class="buy__row-name">{link.name}</span>
            <span class="buy__row-note">{link.note}</span>
          </span>
          {link.badge && <span class="buy__badge">{link.badge}</span>}
          <span class="buy__row-arrow" aria-hidden="true">→</span>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ══ FOOTER ════════════════════════════════ -->
<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__top">
      <p class="footer__title">{c.footer.title}</p>
      <div class="footer__langs">
        <a href="/"    class:list={['footer__lang', { 'footer__lang--active': locale === 'en' }]}>EN</a>
        <a href="/ru/" class:list={['footer__lang', { 'footer__lang--active': locale === 'ru' }]}>RU</a>
      </div>
    </div>
    <div class="ornament" style="margin: 2rem 0"><span>✦</span></div>
    <div class="footer__bottom">
      <p class="footer__copy">{c.footer.copyright}</p>
      <a href="https://www.svetadorosheva.com" target="_blank" rel="noopener" class="footer__site">
        svetadorosheva.com
      </a>
    </div>
  </div>
</footer>


<script>
import gsap from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';

gsap.registerPlugin(ScrollTrigger);

// ── Hero entrance ────────────────────────────────────
gsap.set('[data-hero-logo]',    { opacity: 0, y: 24 });
gsap.set('[data-hero-tagline]', { opacity: 0, y: 12 });
gsap.set('[data-hero-edition]', { opacity: 0 });
gsap.set('[data-hero-cta]',     { opacity: 0, y: 12 });

const heroTl = gsap.timeline({ defaults: { ease: 'power3.out' }, delay: 0.15 });
heroTl
  .to('[data-hero-logo]',    { opacity: 1, y: 0, duration: 1.0 })
  .to('[data-hero-tagline]', { opacity: 1, y: 0, duration: 0.7 }, '-=0.4')
  .to('[data-hero-edition]', { opacity: 1, duration: 0.6 }, '-=0.3')
  .to('[data-hero-cta]',     { opacity: 1, y: 0, duration: 0.6 }, '-=0.3');

// ── Scroll reveal — single elements ─────────────────
gsap.utils.toArray<HTMLElement>('[data-reveal]').forEach(el => {
  gsap.from(el, {
    scrollTrigger: {
      trigger: el,
      start: 'top 88%',
      toggleActions: 'play none none none',
    },
    opacity: 0,
    y: 32,
    duration: 0.9,
    ease: 'power3.out',
  });
});

// ── Scroll reveal — stagger groups ──────────────────
const staggerGroups = document.querySelectorAll<HTMLElement>('.mechanic__list, .gallery__grid, .buy__list, .buy__grid');
staggerGroups.forEach(grid => {
  const items = grid.querySelectorAll<HTMLElement>('[data-reveal-stagger]');
  if (!items.length) return;
  gsap.from(items, {
    scrollTrigger: {
      trigger: grid,
      start: 'top 85%',
      toggleActions: 'play none none none',
    },
    opacity: 0,
    y: 40,
    duration: 0.8,
    stagger: 0.1,
    ease: 'power3.out',
  });
});

// ── Facts counter animation ──────────────────────────
const factNums = document.querySelectorAll<HTMLElement>('.about__fact-num');
factNums.forEach(el => {
  const target = el.textContent?.trim();
  if (!target || isNaN(Number(target))) return; // skip '∞' and non-numbers
  const end = Number(target);
  ScrollTrigger.create({
    trigger: el,
    start: 'top 85%',
    onEnter: () => {
      gsap.from({ val: 0 }, {
        val: end,
        duration: 1.4,
        ease: 'power2.out',
        onUpdate: function() {
          el.textContent = Math.round(this.targets()[0].val).toLocaleString();
        },
      });
    },
    once: true,
  });
});

// ── Video section reveal ─────────────────────────────
gsap.from('.video__wrap', {
  scrollTrigger: { trigger: '.video__wrap', start: 'top 85%', toggleActions: 'play none none none' },
  opacity: 0,
  scale: 0.97,
  duration: 1.1,
  ease: 'power3.out',
});
</script>

</Layout>

<style>
/* ── Nav ─────────────────────── */
.nav { position:fixed; top:0; left:0; right:0; z-index:100; padding:1.25rem 0; background:rgba(250,248,244,0.92); backdrop-filter:blur(12px); -webkit-backdrop-filter:blur(12px); border-bottom:1px solid rgba(0,0,0,.06); }
.nav__inner { display:flex; align-items:center; justify-content:space-between; }
.nav__logo { color:var(--ink); transition:opacity .2s; }
.nav__logo:hover { opacity:.5; }
.nav__langs { display:flex; align-items:center; gap:.4rem; font-size:.75rem; letter-spacing:.1em; }
.nav__lang { color:var(--ink-light); transition:color .2s; padding:.2rem .1rem; }
.nav__lang:hover, .nav__lang--active { color:var(--ink); }
.nav__lang--active { font-weight:500; }
.nav__sep { color:var(--ink-light); }

/* ── Hero ────────────────────── */
.hero { min-height:100dvh; display:flex; flex-direction:column; background:#fff; position:relative; }
.hero__inner { flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; padding-top:7rem; padding-bottom:3rem; gap:1.25rem; }
.hero__logo { width:clamp(240px,55vw,580px); height:auto; display:block; }
.hero__tagline { font-size:.72rem; letter-spacing:.28em; text-transform:uppercase; color:#888; margin:0.5rem 0 0; }
.hero__edition { font-size:.68rem; letter-spacing:.14em; text-transform:uppercase; color:#bbb; margin:0; }
.hero__cta { display:flex; gap:1rem; flex-wrap:wrap; justify-content:center; margin-top:1rem; }
.hero__scroll { display:flex; justify-content:center; padding:2rem; }
.hero__scroll-line { width:1px; height:48px; background:linear-gradient(to bottom,var(--aka),transparent); animation:scrollPulse 2.5s ease-in-out infinite; }
@keyframes scrollPulse { 0%,100%{opacity:.2;transform:scaleY(1)} 50%{opacity:.7;transform:scaleY(1.1)} }

/* ── Pullquote ───────────────── */
.pullquote { padding:var(--section-py) 0; background:var(--washi-2); }
.pullquote__text { font-family:var(--font-serif); font-style:italic; font-size:clamp(1.5rem,3.2vw,2.4rem); font-weight:500; line-height:1.4; text-align:center; color:var(--ink); max-width:800px; margin:1.5rem auto; padding:0 1rem; }

/* ── About ───────────────────── */
.about { padding:var(--section-py) 0; background:var(--washi); }
.about__inner { display:grid; grid-template-columns:1fr 1fr; gap:clamp(2rem,6vw,6rem); align-items:start; }
.about__title { font-size:clamp(2.8rem,7vw,6.5rem); margin:.75rem 0 2rem; color:var(--ink); font-weight:700; line-height:.95; }
.about__body { color:var(--ink-mid); margin-bottom:1rem; font-size:1rem; }
.about__body em { color:var(--aka); font-style:normal; }
.about__facts { display:flex; gap:3rem; margin-top:3rem; padding-top:2.5rem; border-top:1px solid rgba(0,0,0,.1); }
.about__fact { display:flex; flex-direction:column; }
.about__fact-num { font-family:var(--font-serif); font-size:clamp(3rem,7vw,5.5rem); font-weight:500; color:var(--aka); line-height:.9; letter-spacing:-.02em; }
.about__fact-label { font-size:.65rem; letter-spacing:.16em; text-transform:uppercase; color:var(--ink-light); margin-top:.6rem; max-width:100px; line-height:1.5; }
.about__gallery { display:grid; grid-template-columns:1fr 1fr; gap:.6rem; }
.about__img { background:var(--washi-2); border:1px solid rgba(0,0,0,.08); aspect-ratio:4/3; border-radius:1px; overflow:hidden; }
.about__img--1 { grid-column:1/-1; aspect-ratio:16/9; }
.about__img img { width:100%; height:100%; object-fit:cover; display:block; transition:transform .5s ease; }
.about__img:hover img { transform:scale(1.03); }

/* ── Mechanic — editorial list ── */
.mechanic { padding:var(--section-py) 0; background:var(--washi-2); }

.mechanic__title {
  font-size:clamp(2.8rem,7vw,6.5rem);
  font-weight:700;
  line-height:.95;
  margin:.75rem 0 0;
  color:var(--ink);
}

.mechanic__list { margin-top:3.5rem; border-top:1px solid rgba(0,0,0,.1); }

.mechanic__item {
  display:grid;
  grid-template-columns: 3.5rem 1fr auto;
  gap:0 2.5rem;
  align-items:center;
  padding:2.8rem 0;
  border-bottom:1px solid rgba(0,0,0,.08);
  position:relative;
  overflow:hidden;
  transition:background .25s;
}
.mechanic__item:hover { background:rgba(0,0,0,.02); }

.mechanic__index {
  font-family:var(--font-serif);
  font-style:italic;
  font-size:clamp(.85rem,1.5vw,1rem);
  color:var(--aka);
  opacity:.4;
  letter-spacing:.04em;
  align-self:start;
  padding-top:.35em;
  flex-shrink:0;
}

.mechanic__item-body {
  display:flex;
  flex-direction:column;
  gap:.55rem;
}

.mechanic__label {
  font-family:var(--font-serif);
  font-size:clamp(1.5rem,3vw,2.2rem);
  font-weight:500;
  color:var(--ink);
  letter-spacing:-.01em;
  line-height:1.1;
}

.mechanic__body {
  font-size:.92rem;
  color:var(--ink-mid);
  line-height:1.75;
  max-width:520px;
}

.mechanic__kanji {
  font-family:var(--font-serif), serif;
  font-size:clamp(4.5rem,10vw,9rem);
  color:rgba(200,16,46,.07);
  line-height:1;
  pointer-events:none;
  user-select:none;
  flex-shrink:0;
  transition:color .35s;
}
.mechanic__item:hover .mechanic__kanji { color:rgba(200,16,46,.13); }

/* ── Nav logo ────────────────── */
.nav__logo-img { display:block; height:36px; width:36px; fill:var(--ink); opacity:.85; transition:opacity .2s; }
.nav__logo:hover .nav__logo-img { opacity:.5; }

/* ── Mitate Gallery ──────────── */
.mitate-gallery { padding:var(--section-py) 0; background:var(--washi); }
.mitate-gallery__title { font-size:clamp(2.5rem,6vw,5.5rem); text-align:center; margin:.75rem 0 1rem; color:var(--ink); font-weight:700; line-height:1; }
.mitate-gallery__intro { text-align:center; color:var(--ink-mid); font-size:.88rem; max-width:560px; margin:0 auto 3rem; line-height:1.8; letter-spacing:.02em; }

/* ── Video ───────────────────── */
.video-section { padding:var(--section-py) 0; background:var(--washi); }
