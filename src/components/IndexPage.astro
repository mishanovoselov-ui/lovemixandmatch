---
import Layout from '../layouts/Layout.astro';
import BookFlip from './BookFlip.astro';
import type { Locale, SiteContent } from '../i18n/content.ts';

export interface Props {
  locale: Locale;
  c: SiteContent;
}

const { locale, c } = Astro.props;

const langPaths: Record<Locale, string> = { en: '/', ru: '/ru/' };
const langLabels: Record<Locale, { en: string; ru: string }> = {
  en: { en: 'EN', ru: 'RU' },
  ru: { en: 'EN', ru: 'РУ' },
};
const labels = langLabels[locale];
---

<Layout
  title={c.meta.title}
  description={c.meta.description}
  lang={c.meta.lang}
>

<!-- ══ NAV ══════════════════════════════════ -->
<nav class="nav">
  <div class="container nav__inner">
    <a href={langPaths[locale]} class="nav__logo" aria-label={c.footer.title}>
      <!-- TODO: replace /logo.svg with final book logo from designer -->
      <img src="/logo.svg" alt="Love" width="80" height="28" class="nav__logo-img" />
    </a>
    <div class="nav__langs">
      <a href="/"    class:list={['nav__lang', { 'nav__lang--active': locale === 'en' }]} aria-current={locale === 'en' ? 'page' : undefined}>{labels.en}</a>
      <span class="nav__sep">·</span>
      <a href="/ru/" class:list={['nav__lang', { 'nav__lang--active': locale === 'ru' }]} aria-current={locale === 'ru' ? 'page' : undefined}>{labels.ru}</a>
    </div>
  </div>
</nav>

<!-- ══ HERO ══════════════════════════════════ -->
<section class="hero">
  <div class="container hero__inner">

    <img
      src="/images/love-logo.png"
      alt="Love — Mix & Match Shunga Ehon by Sveta Dorosheva"
      class="hero__logo"
      data-hero-logo
      width="600"
      height="auto"
    />

    <p class="hero__tagline" data-hero-tagline>
      {c.hero.subtitle[0]} &nbsp;·&nbsp; {c.hero.subtitle[1]}
    </p>

    <p class="hero__edition" data-hero-edition>
      {c.hero.metaEdition} &nbsp;·&nbsp; {c.hero.metaExtra}
    </p>

    <div class="hero__cta" data-hero-cta>
      <a href="#buy" class="btn btn-primary">{c.hero.ctaPrimary}</a>
      <a href="#mechanic" class="btn btn-ghost">{c.hero.ctaSecondary}</a>
    </div>

  </div>
  <div class="hero__scroll" aria-hidden="true"><div class="hero__scroll-line"></div></div>
</section>

<!-- ══ PULLQUOTE ═════════════════════════════ -->
<section class="pullquote">
  <div class="container">
    <div class="ornament" data-reveal><span>✦</span></div>
    <blockquote class="pullquote__text" data-reveal>{c.pullquote}</blockquote>
    <div class="ornament" data-reveal><span>✦</span></div>
  </div>
</section>

<!-- ══ ABOUT ═════════════════════════════════ -->
<section class="about" id="about">
  <div class="container about__inner">
    <div class="about__content">
      <p class="eyebrow" data-reveal>{c.about.eyebrow}</p>
      <h2 class="about__title" data-reveal>
        {c.about.title.map((line, i) => (
          <>{line}{i < c.about.title.length - 1 && <br/>}</>
        ))}
      </h2>
      {c.about.body.map(para => (
        <p class="about__body" data-reveal set:html={para.replace(/\*\*(.+?)\*\*/g, '<em>$1</em>')} />
      ))}
      <div class="about__facts" data-reveal>
        <div class="about__fact">
          <span class="about__fact-num">1600</span>
          <span class="about__fact-label">{c.about.factCombinations}</span>
        </div>
        <div class="about__fact">
          <span class="about__fact-num">2</span>
          <span class="about__fact-label">{c.about.factVolumes}</span>
        </div>
        <div class="about__fact">
          <span class="about__fact-num">∞</span>
          <span class="about__fact-label">{c.about.factEdition}</span>
        </div>
      </div>
    </div>
    <div class="about__gallery">
      <div class="about__img about__img--1"><span class="about__img-label">{c.about.imgLabels[0]}</span></div>
      <div class="about__img about__img--2"><span class="about__img-label">{c.about.imgLabels[1]}</span></div>
      <div class="about__img about__img--3"><span class="about__img-label">{c.about.imgLabels[2]}</span></div>
    </div>
  </div>
</section>

<!-- ══ MECHANIC ═══════════════════════════════ -->
<section class="mechanic" id="mechanic">
  <div class="container">
    <p class="eyebrow" style="text-align:center" data-reveal>{c.mechanic.eyebrow}</p>
    <h2 class="mechanic__title" data-reveal>{c.mechanic.title}</h2>
    <div class="mechanic__grid">
      {c.mechanic.items.map(item => (
        <article class="mechanic__card" data-reveal-stagger>
          <div class="mechanic__kanji" aria-hidden="true">{item.term}</div>
          <h3 class="mechanic__label">{item.label}</h3>
          <p class="mechanic__body">{item.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- ══ VIDEO ══════════════════════════════════ -->
<section class="video-section">
  <div class="container">
    <p class="eyebrow" style="text-align:center" data-reveal>{c.video.eyebrow}</p>
    <h2 class="video__title" data-reveal>{c.video.title}</h2>
    <div class="video__wrap" data-reveal>
      {c.video.youtubeId && c.video.youtubeId !== 'YOUTUBE_ID_HERE' ? (
        <iframe
          src={`https://www.youtube-nocookie.com/embed/${c.video.youtubeId}?rel=0&modestbranding=1&color=white`}
          title={c.video.title}
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      ) : (
        <!-- Placeholder until YouTube ID is set in content.ts -->
        <div class="video__placeholder">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none" aria-hidden="true">
            <circle cx="24" cy="24" r="23" stroke="currentColor" stroke-width="1" opacity="0.3"/>
            <path d="M19 16L35 24L19 32V16Z" fill="currentColor" opacity="0.4"/>
          </svg>
          <span>Video — add YouTube ID to content.ts</span>
        </div>
      )}
    </div>
  </div>
</section>

<!-- ══ BOOK FLIP (kasane interactive) ══════════ -->
<section class="kasane" id="kasane">
  <div class="container">
    <p class="eyebrow" style="text-align:center" data-reveal>{c.gallery.eyebrow}</p>
    <h2 class="kasane__title" data-reveal>{c.gallery.title}</h2>
    <p class="kasane__sub" data-reveal>
      {locale === 'ru'
        ? 'Листайте каждый том отдельно — создавайте свою комбинацию'
        : 'Flip each volume independently — create your own combination'}
    </p>
    <div data-reveal>
      <BookFlip
        leftImages={c.gallery.images.filter((_, i) => i % 2 === 0)}
        rightImages={c.gallery.images.filter((_, i) => i % 2 === 1)}
        labelLeft={locale === 'ru' ? 'Том I' : 'Volume I'}
        labelRight={locale === 'ru' ? 'Том II' : 'Volume II'}
        labelPrev={locale === 'ru' ? 'Назад' : 'Prev'}
        labelNext={locale === 'ru' ? 'Далее' : 'Next'}
        labelOf={locale === 'ru' ? '/' : '/'}
      />
    </div>
  </div>
</section>

<!-- ══ ARTIST ════════════════════════════════ -->
<section class="artist">
  <div class="container artist__inner">
    <div class="artist__portrait">
      <!-- swap: <img src="/images/artist.jpg" alt={c.artist.portraitAlt} /> -->
      <div class="artist__portrait-placeholder">
        <span set:html={c.artist.portraitPlaceholder.replace('\n', '<br/>')} />
      </div>
      <div class="artist__portrait-frame" aria-hidden="true"></div>
    </div>
    <div class="artist__content">
      <p class="eyebrow">{c.artist.eyebrow}</p>
      <h2 class="artist__name">{c.artist.name}</h2>
      {c.artist.bio.map(p => <p class="artist__bio">{p}</p>)}
      <a href="https://svetadorosheva.com" target="_blank" rel="noopener" class="btn btn-outline artist__link">
        {c.artist.cta}
      </a>
    </div>
  </div>
</section>

<!-- ══ BUY ═════════════════════════════════════ -->
<section class="buy" id="buy">
  <div class="container">
    <p class="eyebrow" style="text-align:center">{c.buy.eyebrow}</p>
    <h2 class="buy__title">{c.buy.title}</h2>
    <p class="buy__subtitle">{c.buy.subtitle}</p>
    <div class="buy__grid">
      {c.buy.links.map(link => (
        <a
          href={link.url}
          target={link.url.startsWith('mailto') ? undefined : '_blank'}
          rel={link.url.startsWith('mailto') ? undefined : 'noopener'}
          class:list={['buy__card', { 'buy__card--featured': link.featured }]}
        >
          {link.badge && <span class="buy__badge">{link.badge}</span>}
          <span class="buy__card-name">{link.name}</span>
          <span class="buy__card-note">{link.note}</span>
          <span class="buy__card-arrow" aria-hidden="true">→</span>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ══ FOOTER ════════════════════════════════ -->
<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__top">
      <p class="footer__title">{c.footer.title}</p>
      <div class="footer__langs">
        <a href="/"    class:list={['footer__lang', { 'footer__lang--active': locale === 'en' }]}>EN</a>
        <a href="/ru/" class:list={['footer__lang', { 'footer__lang--active': locale === 'ru' }]}>RU</a>
      </div>
    </div>
    <div class="ornament" style="margin: 2rem 0"><span>✦</span></div>
    <div class="footer__bottom">
      <p class="footer__copy">{c.footer.copyright}</p>
      <a href="https://svetadorosheva.com" target="_blank" rel="noopener" class="footer__site">
        svetadorosheva.com
      </a>
    </div>
  </div>
</footer>


<script>
import gsap from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';

gsap.registerPlugin(ScrollTrigger);

// ── Hero entrance ────────────────────────────────────
gsap.set('[data-hero-logo]',    { opacity: 0, y: 24 });
gsap.set('[data-hero-tagline]', { opacity: 0, y: 12 });
gsap.set('[data-hero-edition]', { opacity: 0 });
gsap.set('[data-hero-cta]',     { opacity: 0, y: 12 });

const heroTl = gsap.timeline({ defaults: { ease: 'power3.out' }, delay: 0.15 });
heroTl
  .to('[data-hero-logo]',    { opacity: 1, y: 0, duration: 1.0 })
  .to('[data-hero-tagline]', { opacity: 1, y: 0, duration: 0.7 }, '-=0.4')
  .to('[data-hero-edition]', { opacity: 1, duration: 0.6 }, '-=0.3')
  .to('[data-hero-cta]',     { opacity: 1, y: 0, duration: 0.6 }, '-=0.3');

// ── Scroll reveal — single elements ─────────────────
gsap.utils.toArray<HTMLElement>('[data-reveal]').forEach(el => {
  gsap.from(el, {
    scrollTrigger: {
      trigger: el,
      start: 'top 88%',
      toggleActions: 'play none none none',
    },
    opacity: 0,
    y: 32,
    duration: 0.9,
    ease: 'power3.out',
  });
});

// ── Scroll reveal — stagger groups ──────────────────
const staggerGroups = document.querySelectorAll<HTMLElement>('.mechanic__grid, .gallery__grid, .buy__grid');
staggerGroups.forEach(grid => {
  const items = grid.querySelectorAll<HTMLElement>('[data-reveal-stagger]');
  if (!items.length) return;
  gsap.from(items, {
    scrollTrigger: {
      trigger: grid,
      start: 'top 85%',
      toggleActions: 'play none none none',
    },
    opacity: 0,
    y: 40,
    duration: 0.8,
    stagger: 0.1,
    ease: 'power3.out',
  });
});

// ── Facts counter animation ──────────────────────────
const factNums = document.querySelectorAll<HTMLElement>('.about__fact-num');
factNums.forEach(el => {
  const target = el.textContent?.trim();
  if (!target || isNaN(Number(target))) return; // skip '∞' and non-numbers
  const end = Number(target);
  ScrollTrigger.create({
    trigger: el,
    start: 'top 85%',
    onEnter: () => {
      gsap.from({ val: 0 }, {
        val: end,
        duration: 1.4,
        ease: 'power2.out',
        onUpdate: function() {
          el.textContent = Math.round(this.targets()[0].val).toLocaleString();
        },
      });
    },
    once: true,
  });
});

// ── Video section reveal ─────────────────────────────
gsap.from('.video__wrap', {
  scrollTrigger: { trigger: '.video__wrap', start: 'top 85%', toggleActions: 'play none none none' },
  opacity: 0,
  scale: 0.97,
  duration: 1.1,
  ease: 'power3.out',
});
</script>

</Layout>

<style>
/* ── Nav ─────────────────────── */
.nav { position:fixed; top:0; left:0; right:0; z-index:100; padding:1.25rem 0; background:rgba(12,10,7,0.92); backdrop-filter:blur(12px); -webkit-backdrop-filter:blur(12px); border-bottom:1px solid rgba(196,154,60,.06); }
.nav__inner { display:flex; align-items:center; justify-content:space-between; }
.nav__logo { color:var(--gold); transition:opacity .2s; }
.nav__logo:hover { opacity:.6; }
.nav__langs { display:flex; align-items:center; gap:.4rem; font-size:.75rem; letter-spacing:.1em; }
.nav__lang { color:var(--ivory-ghost); transition:color .2s; padding:.2rem .1rem; }
.nav__lang:hover, .nav__lang--active { color:var(--ivory); }
.nav__lang--active { font-weight:500; }
.nav__sep { color:var(--ivory-ghost); }

/* ── Hero ────────────────────── */
.hero { min-height:100dvh; display:flex; flex-direction:column; background:#fff; position:relative; }
.hero__inner { flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; padding-top:7rem; padding-bottom:3rem; gap:1.25rem; }
.hero__logo { width:clamp(240px,55vw,580px); height:auto; display:block; }
.hero__tagline { font-size:.72rem; letter-spacing:.28em; text-transform:uppercase; color:#888; margin:0.5rem 0 0; }
.hero__edition { font-size:.68rem; letter-spacing:.14em; text-transform:uppercase; color:#bbb; margin:0; }
.hero__cta { display:flex; gap:1rem; flex-wrap:wrap; justify-content:center; margin-top:1rem; }
.hero__scroll { display:flex; justify-content:center; padding:2rem; }
.hero__scroll-line { width:1px; height:48px; background:linear-gradient(to bottom,#c49a3c,transparent); animation:scrollPulse 2.5s ease-in-out infinite; }
@keyframes scrollPulse { 0%,100%{opacity:.2;transform:scaleY(1)} 50%{opacity:.7;transform:scaleY(1.1)} }

/* ── Pullquote ───────────────── */
.pullquote { padding:var(--section-py) 0; background:var(--charcoal); }
.pullquote__text { font-family:var(--font-serif); font-style:italic; font-size:clamp(1.1rem,2.2vw,1.6rem); font-weight:300; line-height:1.65; text-align:center; color:var(--ivory); max-width:720px; margin:1.5rem auto; padding:0 1rem; opacity:.9; }

/* ── About ───────────────────── */
.about { padding:var(--section-py) 0; background:var(--obsidian); }
.about__inner { display:grid; grid-template-columns:1fr 1fr; gap:clamp(2rem,6vw,6rem); align-items:start; }
.about__title { font-size:clamp(1.8rem,4vw,3rem); margin:.75rem 0 1.5rem; color:var(--ivory); }
.about__body { color:var(--ivory-dim); margin-bottom:1rem; font-size:1rem; }
.about__body em { color:var(--gold-light); font-style:normal; }
.about__facts { display:flex; gap:2.5rem; margin-top:2.5rem; padding-top:2rem; border-top:1px solid rgba(196,154,60,.15); }
.about__fact { display:flex; flex-direction:column; }
.about__fact-num { font-family:var(--font-serif); font-size:2.5rem; font-weight:300; color:var(--gold); line-height:1; }
.about__fact-label { font-size:.68rem; letter-spacing:.12em; text-transform:uppercase; color:var(--ivory-ghost); margin-top:.3rem; }
.about__gallery { display:grid; grid-template-columns:1fr 1fr; gap:.6rem; }
.about__img { background:var(--charcoal); border:1px solid rgba(196,154,60,.08); display:flex; align-items:center; justify-content:center; aspect-ratio:4/3; border-radius:1px; }
.about__img--1 { grid-column:1/-1; aspect-ratio:16/9; }
.about__img-label { font-size:.72rem; color:var(--ivory-ghost); letter-spacing:.1em; }

/* ── Mechanic ─────────────────── */
.mechanic { padding:var(--section-py) 0; background:var(--charcoal); }
.mechanic__title { font-size:clamp(1.6rem,3.5vw,2.5rem); text-align:center; margin:.75rem 0 3.5rem; color:var(--ivory); }
.mechanic__grid { display:grid; grid-template-columns:repeat(2,1fr); gap:1px; background:rgba(196,154,60,.1); border:1px solid rgba(196,154,60,.1); }
.mechanic__card { background:var(--charcoal); padding:3rem 2.5rem; display:flex; flex-direction:column; gap:.75rem; transition:background .25s; position:relative; overflow:hidden; }
.mechanic__card:hover { background:var(--ash); }
.mechanic__kanji { position:absolute; top:1.5rem; right:1.75rem; font-size:3.5rem; color:rgba(196,154,60,.08); font-family:serif; line-height:1; transition:color .25s; pointer-events:none; }
.mechanic__card:hover .mechanic__kanji { color:rgba(196,154,60,.14); }
.mechanic__label { font-family:var(--font-serif); font-size:1.4rem; font-weight:400; color:var(--gold-light); letter-spacing:.02em; }
.mechanic__body { font-size:.9rem; color:var(--ivory-dim); line-height:1.7; }

/* ── Nav logo ────────────────── */
.nav__logo-img { display:block; height:28px; width:auto; opacity:.9; transition:opacity .2s; }
.nav__logo:hover .nav__logo-img { opacity:.6; }

/* ── Video ───────────────────── */
.video-section { padding:var(--section-py) 0; background:var(--charcoal); }
.video__title { font-size:clamp(1.6rem,3.5vw,2.5rem); text-align:center; margin:.75rem 0 3rem; color:var(--ivory); }
.video__wrap { position:relative; width:100%; max-width:900px; margin:0 auto; aspect-ratio:16/9; background:var(--obsidian); border:1px solid rgba(196,154,60,.1); overflow:hidden; }
.video__wrap iframe { position:absolute; inset:0; width:100%; height:100%; border:none; }
.video__placeholder { position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:1rem; color:var(--ivory-ghost); font-size:.8rem; letter-spacing:.1em; }

/* ── Kasane / Book Flip ──────── */
.kasane { padding:var(--section-py) 0; background:var(--obsidian); }
.kasane__title { font-size:clamp(1.6rem,3.5vw,2.5rem); text-align:center; margin:.75rem 0 .75rem; color:var(--ivory); }
.kasane__sub { text-align:center; color:var(--ivory-dim); font-size:.85rem; margin-bottom:3rem; letter-spacing:.04em; }

/* ── Artist ──────────────────── */
.artist { padding:var(--section-py) 0; background:var(--charcoal); }
.artist__inner { display:grid; grid-template-columns:300px 1fr; gap:clamp(2rem,6vw,6rem); align-items:center; }
.artist__portrait { position:relative; aspect-ratio:3/4; }
.artist__portrait-placeholder { width:100%; height:100%; background:var(--ash); border:1px solid rgba(196,154,60,.12); display:flex; align-items:center; justify-content:center; font-size:.85rem; color:var(--ivory-ghost); text-align:center; line-height:2; }
.artist__portrait-frame { position:absolute; inset:10px; border:1px solid rgba(196,154,60,.2); pointer-events:none; }
.artist__name { font-size:clamp(1.8rem,3.5vw,2.8rem); margin:.75rem 0 1.5rem; color:var(--ivory); }
.artist__bio { color:var(--ivory-dim); margin-bottom:1rem; }
.artist__link { margin-top:2rem; }

/* ── Buy ──────────────────────── */
.buy { padding:var(--section-py) 0; background:var(--obsidian); }
.buy .eyebrow { color:var(--gold); }
.buy__title { font-size:clamp(1.8rem,4vw,2.75rem); text-align:center; margin:.75rem 0 1rem; color:var(--ivory); }
.buy__subtitle { text-align:center; color:var(--ivory-dim); font-size:.9rem; max-width:500px; margin:0 auto 3rem; }
.buy__grid { display:grid; grid-template-columns:repeat(2,1fr); gap:1px; background:rgba(196,154,60,.1); border:1px solid rgba(196,154,60,.1); }
.buy__card { display:flex; flex-direction:column; padding:2rem 2.5rem; background:rgba(10,8,5,.6); transition:background .25s; position:relative; }
.buy__card:hover { background:rgba(196,154,60,.07); }
.buy__card--featured { background:rgba(196,154,60,.06); }
.buy__badge { font-size:.62rem; letter-spacing:.2em; text-transform:uppercase; color:var(--gold); margin-bottom:.5rem; }
.buy__card-name { font-family:var(--font-serif); font-size:1.35rem; color:var(--ivory); margin-bottom:.3rem; }
.buy__card-note { font-size:.8rem; color:rgba(240,232,212,.4); }
.buy__card-arrow { position:absolute; bottom:1.5rem; right:2rem; font-size:1.1rem; color:var(--gold-light); opacity:0; transform:translateX(-8px); transition:opacity .25s,transform .25s; }
.buy__card:hover .buy__card-arrow { opacity:1; transform:translateX(0); }

/* ── Footer ──────────────────── */
.footer { padding:4rem 0 3rem; background:var(--ink); color:var(--ivory); }
.footer__top { display:flex; align-items:center; justify-content:space-between; }
.footer__title { font-family:var(--font-serif); font-style:italic; font-size:1.1rem; letter-spacing:.04em; color:var(--ivory); opacity:.7; }
.footer__langs { display:flex; gap:1.5rem; font-size:.75rem; letter-spacing:.1em; }
.footer__lang { color:rgba(240,232,212,.3); transition:color .2s; }
.footer__lang:hover, .footer__lang--active { color:var(--ivory); }
.footer__bottom { display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:1rem; }
.footer__copy { font-size:.76rem; color:rgba(240,232,212,.3); max-width:560px; }
.footer__site { font-size:.76rem; color:var(--gold-light); letter-spacing:.05em; transition:opacity .2s; opacity:.7; }
.footer__site:hover { opacity:1; }

/* ── Responsive ──────────────── */
@media (max-width: 900px) {
  .about__inner, .artist__inner { grid-template-columns:1fr; }
  .about__gallery { display:none; }
  .mechanic__grid { grid-template-columns:1fr; }
  .buy__grid { grid-template-columns:1fr; }
  .footer__top, .footer__bottom { flex-direction:column; gap:.75rem; text-align:center; }
}
@media (max-width: 540px) {
