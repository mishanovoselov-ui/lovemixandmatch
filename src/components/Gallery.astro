---
/**
 * Gallery — Mitate image grid
 *
 * Displays artwork images in a responsive grid.
 * Each cell optionally holds a paired image that cross-fades in on hover,
 * embodying the mitate concept: one image, two readings.
 *
 * Usage:
 *   import Gallery from './Gallery.astro';
 *
 *   <Gallery items={[
 *     {
 *       src: '/images/details/detail-01.jpg',
 *       alt: 'Volume I — detail 1',
 *       pair: { src: '/images/details/detail-01b.jpg', alt: 'Volume II — detail 1' },
 *       caption: 'Spring, alone',
 *     },
 *     ...
 *   ]} />
 *
 * Image dimensions: 800×1067px (3:4) recommended for 2× displays.
 * Drop files into public/images/details/ and set src paths.
 *
 * When src is empty the cell renders as a placeholder — safe to deploy
 * before final artwork arrives.
 */

export interface GalleryItem {
  src: string;
  alt: string;
  pair?: { src: string; alt: string };
  caption?: string;
}

export interface Props {
  items: GalleryItem[];
  placeholderCount?: number; // fallback slots when items is empty
}

const { items, placeholderCount = 6 } = Astro.props;

// Fill with placeholder shells if no real images yet
const cells: GalleryItem[] =
  items.length > 0
    ? items
    : Array.from({ length: placeholderCount }, (_, i) => ({
        src: '',
        alt: '',
      }));
---

<div class="gallery__grid">
  {cells.map((item, i) => (
    <figure
      class:list={['gallery__item', { 'gallery__item--has-pair': !!item.pair }]}
      data-reveal-stagger
    >
      <div class="gallery__imgs">

        {/* Primary image or placeholder */}
        {item.src ? (
          <img
            class="gallery__img gallery__img--primary"
            src={item.src}
            alt={item.alt}
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="gallery__placeholder" aria-hidden="true">
            <span class="gallery__placeholder-index">{String(i + 1).padStart(2, '0')}</span>
          </div>
        )}

        {/* Pair / mitate reveal */}
        {item.pair?.src && (
          <img
            class="gallery__img gallery__img--pair"
            src={item.pair.src}
            alt={item.pair.alt}
            loading="lazy"
            decoding="async"
            aria-hidden="true"
          />
        )}

        {/* Kanji mark — appears on hover */}
        <span class="gallery__mark" aria-hidden="true">見立て</span>

      </div>

      {item.caption && (
        <figcaption class="gallery__caption">{item.caption}</figcaption>
      )}
    </figure>
  ))}
</div>

<style>
/* ── Grid ────────────────────────────────────────────── */
.gallery__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: rgba(0, 0, 0, .08);
}

/* ── Cell ────────────────────────────────────────────── */
.gallery__item {
  position: relative;
  aspect-ratio: 3 / 4;
  overflow: hidden;
  background: var(--washi-2);
  cursor: default;
}

.gallery__item--has-pair {
  cursor: crosshair;
}

/* ── Images ──────────────────────────────────────────── */
.gallery__imgs {
  position: relative;
  width: 100%;
  height: 100%;
}

.gallery__img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.gallery__img--primary {
  transition: opacity .55s ease, transform .7s ease;
  z-index: 1;
}

.gallery__img--pair {
  opacity: 0;
  transition: opacity .55s ease;
  z-index: 2;
}

.gallery__item--has-pair:hover .gallery__img--pair,
.gallery__item--has-pair:focus-within .gallery__img--pair {
  opacity: 1;
}

.gallery__item--has-pair:hover .gallery__img--primary,
.gallery__item--has-pair:focus-within .gallery__img--primary {
  opacity: 0;
  transform: scale(1.03);
}

/* ── Placeholder ─────────────────────────────────────── */
.gallery__placeholder {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--washi-2);
  border: 1px solid rgba(0, 0, 0, .06);
}

.gallery__placeholder-index {
  font-family: var(--font-serif);
  font-style: italic;
  font-size: clamp(3rem, 8vw, 6rem);
  color: rgba(0, 0, 0, .07);
  line-height: 1;
  user-select: none;
}

/* ── Kanji mark ──────────────────────────────────────── */
.gallery__mark {
  position: absolute;
  bottom: .6rem;
  right: .8rem;
  z-index: 3;
  font-family: var(--font-serif);
  font-size: 1.4rem;
  line-height: 1;
  color: rgba(200, 16, 46, 0);
  pointer-events: none;
  user-select: none;
  transition: color .4s ease;
}

.gallery__item--has-pair:hover .gallery__mark,
.gallery__item--has-pair:focus-within .gallery__mark {
  color: rgba(200, 16, 46, .22);
}

/* ── Caption ─────────────────────────────────────────── */
.gallery__caption {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 4;
  padding: .6rem .8rem;
  font-size: .65rem;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--washi);
  background: linear-gradient(to top, rgba(13,13,13,.55) 0%, transparent 100%);
  opacity: 0;
  transform: translateY(4px);
  transition: opacity .3s ease, transform .3s ease;
}

.gallery__item:hover .gallery__caption,
.gallery__item:focus-within .gallery__caption {
  opacity: 1;
  transform: translateY(0);
}

/* ── Responsive ──────────────────────────────────────── */
@media (max-width: 720px) {
  .gallery__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 420px) {
  .gallery__grid {
    grid-template-columns: 1fr;
  }
}
</style>
